{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "",
  "functions": {
    "api/*.js": {
      "includeFiles": "docs.config.json,docs/projects/**,docs/areas/**,docs/resources/**,docs/archives/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/docs", "destination": "/public/docs.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
