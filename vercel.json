{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "",
  "functions": {
    "api/*.js": {
      "includeFiles": "docs.config.json,docs/**/*,docs/projects/*,docs/areas/*,docs/resources/*,docs/archives/*"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/public/admin.html" },
    { "source": "/docs", "destination": "/public/docs.html" },
    { "source": "/docs/:category", "destination": "/public/docs.html" },
    { "source": "/docs/:category/:slug", "destination": "/public/docs.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
